{
  "name": "file-to-pdf-converter",
  "version": "1.0.0",
  "description": "Universal file to PDF converter — supports DOCX, XLSX, PPTX, images, TXT, HTML, Markdown",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "express": "^4.22.1",
    "ghostscript-node": "^1.5.0",
    "marked": "^11.1.1",
    "multer": "^1.4.5-lts.1",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.14.0",
    "sharp": "^0.33.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "pdf",
    "converter",
    "docx",
    "xlsx",
    "pptx",
    "libreoffice"
  ],
  "license": "MIT"
